# /etc/nginx/sites-available/imago.example.com

upstream imago_backend {
    server 127.0.0.1:8080;
    keepalive 32;
}

server {
    listen 80;
    server_name imago.example.com;

    # --------------------------------------------------
    # Serve cached images directly (fast path)
    # --------------------------------------------------
    location /cache/ {
        alias /var/www/imagoV2/public/cache/;
        expires 365d;
        add_header Cache-Control "public, immutable";
        add_header X-Cache "HIT";
        access_log off;
        try_files $uri @proxy;
    }

    # --------------------------------------------------
    # Block access to sensitive files
    # --------------------------------------------------
    location ~ /_ {
        deny all;
        return 404;
    }

    location ~ /\. {
        deny all;
        return 404;
    }

    location = /composer.json {
        deny all;
        return 404;
    }

    location = /composer.lock {
        deny all;
        return 404;
    }

    # --------------------------------------------------
    # Proxy all other requests to the AmPHP server
    # --------------------------------------------------
    location / {
        proxy_pass http://imago_backend;
        proxy_http_version 1.1;

        proxy_set_header Host              $host;
        proxy_set_header X-Real-IP         $remote_addr;
        proxy_set_header X-Forwarded-For   $proxy_add_x_forwarded_for;
        proxy_set_header X-Forwarded-Proto $scheme;
        proxy_set_header Connection        "";

        proxy_buffering on;
        proxy_cache_valid 200 30d;
        proxy_cache_use_stale error timeout updating;
        proxy_cache_lock on;

        add_header X-Cache $upstream_cache_status;

        # Long timeout for image processing
        proxy_read_timeout 30s;
        proxy_send_timeout 10s;

        client_max_body_size 1k;
    }
}
